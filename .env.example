# PostHog analytics
VITE_POSTHOG_KEY=phc_xxx
VITE_POSTHOG_HOST=https://b.dmytroai.com

# GEO Test Runner — scripts/geo-runner.ts
#
# CLI providers (flat-rate subscription — no API keys needed):
#   openai  → uses `codex exec` (Codex CLI subscription)
#   claude  → uses `claude -p`  (Claude Code Max subscription)
#
# API providers (pay-per-token — set keys below):
GEMINI_API_KEY=AIza-xxx
PERPLEXITY_API_KEY=pplx-xxx
#
# OPENAI_API_KEY and ANTHROPIC_API_KEY are NOT used by the GEO runner.
# OpenAI and Claude checks run through local CLI subscriptions only.
